re'>
 <v:imagedata src=3D"Help_files/image013.png" o:title=3D""/>
</v:shape><![endif]--><![if !vml]><img width=3D403 height=3D193
src=3D"Help_files/image014.jpg" v:shapes=3D"_x0000_i1035"><![endif]></span>=
</p>

<p class=3DMsoNormal><o:p>&nbsp;</o:p></p>

<p class=3DMsoNormal><u>Explanation of the Half Hourly charts<o:p></o:p></u=
></p>

<p class=3DMsoNormal><o:p>&nbsp;</o:p></p>

<p class=3DMsoNormal align=3Dcenter style=3D'text-align:center'><span
