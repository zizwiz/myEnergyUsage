:247.5pt;
 visibility:visible;mso-wrap-style:square'>
 <v:imagedata src=3D"Help_files/image046.png" o:title=3D""/>
</v:shape><![endif]--><![if !vml]><img width=3D623 height=3D330
src=3D"Help_files/image015.jpg" v:shapes=3D"Picture_x0020_8"><![endif]></sp=
an></p>

<p class=3DMsoNormal>The chart is shaded in such a way as to give a pictori=
al
explanation of the different times in a day. </p>

<ul style=3D'margin-top:0cm' type=3Ddisc>
 <li class=3DMsoNormal style=3D'mso-list:l0 level1 lfo6'>Energy usage is sh=
aded
     dark blue</li>
 <li class=3DMsoNormal style=3D'mso-list:l0 level1 lfo6'>Night time is shad=
ed light
     blue</li>
 <li class=3DMsoNormal style=3D'mso-list:l0 level1 lfo6'>Day light is shade=
d yellow</li>
 <li class=3DMsoNormal style=3D'mso-list:l0 level1 lfo6'>Peak period for en=
ergy is
     shaded grey</li>
 <li class=3DMsoNormal style=3D'mso-list:l0 level1 lfo6'>Sunrise is indicat=
ed with
     a red vertical line</li>
 <li class=3DMsoNormal style=3D'mso-list:l0 level1 lfo6'>Sunset is indicate=
d with
     an orange vertical line</li>
</ul>

<p class=3DMsoNormal><o:p>&nbsp;</o:p></p>

<p class=3DMsoNormal>An interesting fact is that overnight there is a const=
ant
use of energy. As soon as the sun comes up and there is no cloud, we see the
solar panels start to produce energy and the amount of energy that needs to=
 be
imported decreases. The decrease increases as the suns angle increases as t=
he
morning progresses. </p>

<p class=3DMsoNormal><o:p>&nbsp;</o:p></p>

<p class=3DMsoNormal align=3Dcenter style=3D'text-align:center'><span
style=3D'mso-no-proof:yes'><!--[if gte vml 1]><v:shape id=3D"Picture_x0020_=
9"
 o:spid=3D"_x0000_i1033" type=3D"#_x0000_t75" style=3D'width:237.5pt;height=
:119pt;
 visibility:visible;mso-wrap-style:square'>
 <v:imagedata src=3D"Help_files/image048.png" o:title=3D""/>
</v:shape><![endif]--><![if !vml]><img width=3D317 height=3D159
src=3D"Help_files/image016.jpg" v:shapes=3D"Picture_x0020_9"><![endif]></sp=
an></p>

<p class=3DMsoNormal><o:p>&nbsp;</o:p></p>

<p class=3DMsoNormal><o:p>&nbsp;</o:p></p>

<p class=3DMsoNormal><o:p>&nbsp;</o:p></p>

<p class=3DMsoNormal><u>Tooltips<o:p></o:p></u></p>

<p class=3DMsoNormal>If you put your mouse over a charted bar, you will get=
 a
tooltip telling you the date, time, energy used and cost for the half hour =
the
bar represents.</p>

<p class=3DMsoNormal align=3Dcenter style=3D'text-align:center'><span
style=3D'mso-no-proof:yes'><!--[if gte vml 1]><v:shape id=3D"Picture_x0020_=
10"
 o:spid=3D"_x0000_i1032" type=3D"#_x0000_t75" style=3D'width:288.5pt;height=
:126pt;
 visibility:visible;mso-wrap-style:square'>
 <v:imagedata src=3D"Help_files/image050.png" o:title=3D""/>
</v:shape><![endif]--><![if !vml]><img width=3D385 height=3D168
src=3D"Help_files/image017.jpg" v:shapes=3D"Picture_x0020_10"><![endif]></s=
pan></p>

<p class=3DMsoNormal><o:p>&nbsp;</o:p></p>

<p class=3DMsoNormal><u>Viewing multiple days<o:p></o:p></u></p>

<p class=3DMsoNormal>You can view more than one day in the same chart. Just=
 check
the days you want to view in the selection box.</p>

<p class=3DMsoNormal><o:p>&nbsp;</o:p></p>

<p class=3DMsoNormal align=3Dcenter style=3D'text-align:center'><span
style=3D'mso-no-proof:yes'><!--[if gte vml 1]><v:shape id=3D"Picture_x0020_=
5"
 o:spid=3D"_x0000_i1031" type=3D"#_x0000_t75" style=3D'width:162pt;height:8=
9.5pt;
 visibility:visible;mso-wrap-style:square'>
 <v:imagedata src=3D"Help_files/image018.png" o:title=3D""/>
</v:shape><![endif]--><![if !vml]><img width=3D216 height=3D119
src=3D"Help_files/image019.jpg" v:shapes=3D"Picture_x0020_5"><![endif]></sp=
an></p>

<p class=3DMsoNormal>Click show chart and you will see the various days in a
chart.</p>

<p class=3DMsoNormal><o:p>&nbsp;</o:p></p>

<p class=3DMsoNormal align=3Dcenter style=3D'text-align:center'><span
style=3D'mso-no-proof:yes'><!--[if gte vml 1]><v:shape id=3D"_x0000_i1030" =
type=3D"#_x0000_t75"
 style=3D'width:324pt;height:155pt;visibility:visible;mso-wrap-style:square=
'>
 <v:imagedata src=3D"Help_files/image020.png" o:title=3D""/>
</v:shape><![endif]--><![if !vml]><img width=3D432 height=3D207
src=3D"Help_files/image021.jpg" v:shapes=3D"_x0000_i1030"><![endif]></span>=
</p>

<p class=3DMsoNormal><o:p>&nbsp;</o:p></p>

<p class=3DMsoNormal>If you choose days that are not consecutive you will g=
et
gaps in the chart where the missing days will have been.</p>

<p class=3DMsoNormal><o:p>&nbsp;</o:p></p>

<p class=3DMsoNormal align=3Dcenter style=3D'text-align:center'><span
style=3D'mso-no-proof:yes'><!--[if gte vml 1]><v:shape id=3D"Picture_x0020_=
6"
 o:spid=3D"_x0000_i1029" type=3D"#_x0000_t75" style=3D'width:320.5pt;height=
:153.5pt;
 visibility:visible;mso-wrap-style:square'>
 <v:imagedata src=3D"Help_files/image022.png" o:title=3D""/>
</v:shape><![endif]--><![if !vml]><img width=3D427 height=3D205
src=3D"Help_files/image023.jpg" v:shapes=3D"Picture_x0020_6"><![endif]></sp=
an></p>

<p class=3DMsoNormal><o:p>&nbsp;</o:p></p>

<p class=3DMsoNormal>Note the day on the far right of the chart does not ha=
ve a
peak time. Depending on your tariff you may find you can have a whole day on
off-peak energy.</p>

<p class=3DMsoNormal><o:p>&nbsp;</o:p></p>

<p class=3DMsoNormal style=3D'mso-pagination:widow-orphan;mso-layout-grid-a=
lign:
auto;text-autospace:ideograph-other'><u>Viewing the daily data<o:p></o:p></=
u></p>

<p class=3DMsoNormal style=3D'mso-pagination:widow-orphan;mso-layout-grid-a=
lign:
auto;text-autospace:ideograph-other'><o:p>&nbsp;</o:p></p>

<p class=3DMsoNormal style=3D'mso-pagination:widow-orphan;mso-layout-grid-a=
lign:
auto;text-autospace:ideograph-other'>Check the radio button called Daily and
the UI will reset.</p>

<p class=3DMsoNormal align=3Dcenter style=3D'text-align:center;mso-paginati=
on:widow-orphan;
mso-layout-grid-align:auto;text-autospace:ideograph-other'><span
style=3D'mso-no-proof:yes'><!--[if gte vml 1]><v:shape id=3D"Picture_x0020_=
1"
 o:spid=3D"_x0000_i1028" type=3D"#_x0000_t75" style=3D'width:320pt;height:1=
53.5pt;
 visibility:visible;mso-wrap-style:square'>
 <v:imagedata src=3D"Help_files/image024.png" o:title=3D""/>
</v:shape><![endif]--><![if !vml]><img width=3D427 height=3D205
src=3D"Help_files/image025.jpg" v:shapes=3D"Picture_x0020_1"><![endif]></sp=
an></p>

<p class=3DMsoNormal align=3Dcenter style=3D'text-align:center;mso-paginati=
on:widow-orphan;
mso-layout-grid-align:auto;text-autospace:ideograph-other'><o:p>&nbsp;</o:p=
></p>

<p class=3DMsoNormal>Click =93Show Chart=94 to display the daily totals for=
 the month</p>

<p class=3DMsoNormal><o:p>&nbsp;</o:p></p>

<p class=3DMsoNormal align=3Dcenter style=3D'text-align:center'><span
style=3D'mso-no-proof:yes'><!--[if gte vml 1]><v:shape id=3D"Picture_x0020_=
2"
 o:spid=3D"_x0000_i1027" type=3D"#_x0000_t75" style=3D'width:319pt;height:1=
52.5pt;
 visibility:visible;mso-wrap-style:square'>
 <v:imagedata src=3D"Help_files/image026.png" o:title=3D""/>
</v:shape><![endif]--><![if !vml]><img width=3D425 height=3D203
src=3D"Help_files/image027.jpg" v:shapes=3D"Picture_x0020_2"><![endif]></sp=
an></p>

<p class=3DMsoNormal><o:p>&nbsp;</o:p></p>

<p class=3DMsoNormal><u>Save Chart Image<o:p></o:p></u></p>

<p class=3DMsoNormal style=3D'text-align:justify;text-justify:inter-ideogra=
ph'>Click
on the =93Save Chart=94 and you will be able to select where you save the i=
mage and
what you call it. The size you save will depend on the size you have the app
working at. For the best results maximise the app.</p>

<p class=3DMsoNormal><o:p>&nbsp;</o:p></p>

<p class=3DMsoNormal><b><u>Energy Costs<o:p></o:p></u></b></p>

<p class=3DMsoNormal><o:p>&nbsp;</o:p></p>

<p class=3DMsoNormal><u>Json file<o:p></o:p></u></p>

<p class=3DMsoNormal>The tariff data is stored in a .<span class=3DSpellE>j=
son</span>
file which is found in the same directory as the apps exe file. The layout =
of
this file is shown below.</p>

<p class=3DMsoNormal><span style=3D'mso-no-proof:yes'><!--[if gte vml 1]><v=
:shape
 id=3D"Picture_x0020_3" o:spid=3D"_x0000_i1026" type=3D"#_x0000_t75" style=
=3D'width:196pt;
 height:242pt;visibility:visible;mso-wrap-style:square'>
 <v:imagedata src=3D"Help_files/image028.png" o:title=3D""/>
</v:shape><![endif]--><![if !vml]><img width=3D261 height=3D323
src=3D"Help_files/image029.jpg" v:shapes=3D"Picture_x0020_3"><![endif]></sp=
an></p>

<p class=3DMsoNormal><o:p>&nbsp;</o:p></p>

<p class=3DMsoNormal><u>Setting the tariff<o:p></o:p></u></p>

<p class=3DMsoNormal>The tariff that you are on may change and you will wan=
t to calculate
the energy cost with the correct tariffs. Other things that may change coul=
d be
the standing day charge or the NRAB.</p>

<p class=3DMsoNormal><o:p>&nbsp;</o:p></p>

<p class=3DMsoNormal><i>Nuclear Regulated Asset Base (NRAB): Starting from
November 1, 2025, all energy suppliers are be required to pay into the Nucl=
ear
RAB Levy to fund the development and operation of nuclear projects, includi=
ng
Sizewell C. The initial rate for the levy is set at =A33.455 per MWh, which=
 means
a typical small business using 10 000 kWh per year would pay about =A335 ex=
tra
annually.<o:p></o:p></i></p>

<p class=3DMsoNormal><o:p>&nbsp;</o:p></p>

<p class=3DMsoNormal align=3Dcenter style=3D'text-align:center'><span
style=3D'mso-no-proof:yes'><!--[if gte vml 1]><v:shape id=3D"Picture_x0020_=
4"
 o:spid=3D"_x0000_i1025" type=3D"#_x0000_t75" style=3D'width:317pt;height:1=
51.5pt;
 visibility:visible;mso-wrap-style:square'>
 <v:imagedata src=3D"Help_files/image030.png" o:title=3D""/>
</v:shape><![endif]--><![if !vml]><img width=3D423 height=3D202
src=3D"Help_files/image031.jpg" v:shapes=3D"Picture_x0020_4"><![endif]></sp=
an></p>

<p class=3DMsoNormal><o:p>&nbsp;</o:p></p>

<p class=3DMsoNormal>You can </p>

<ul style=3D'margin-top:0cm' type=3Ddisc>
 <li class=3DMsoNormal style=3D'mso-list:l3 level1 lfo7'>Edit an entry by c=
licking
     on the tariff entry on the right-hand side.</li>
 <li class=3DMsoNormal style=3D'mso-list:l3 level1 lfo7'>Create a new entry=
 into
     the .<span class=3DSpellE>json</span> file by clicking on the new butt=
on. </li>
 <li class=3DMsoNormal style=3D'mso-list:l3 level1 lfo7'>Save the updated o=
r new
     entry by clicking on the save button.</li>
 <li class=3DMsoNormal style=3D'mso-list:l3 level1 lfo7'>Delete the entry by
     clicking on the delete button <span style=3D'mso-spacerun:yes'>=A0</sp=
an></li>
</ul>

<p class=3DMsoNormal align=3Dcenter style=3D'text-align:center'><o:p>&nbsp;=
</o:p></p>

<p class=3DMsoNormal><span lang=3DEN style=3D'mso-ansi-language:EN'>End of =
File<o:p></o:p></span></p>

</div>

</body>

